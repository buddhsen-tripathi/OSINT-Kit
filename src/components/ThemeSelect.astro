---
import Default from '@astrojs/starlight/components/ThemeSelect.astro';
---

<div class="theme-toggle-wrapper">
  <Default />
  <div class="theme-buttons" role="group" aria-label="Theme">
    <button type="button" data-theme="light" aria-label="Light theme">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
      </svg>
    </button>
    <button type="button" data-theme="dark" aria-label="Dark theme">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </button>
  </div>
</div>

<script>
  for (const btn of document.querySelectorAll<HTMLButtonElement>('.theme-buttons button')) {
    btn.addEventListener('click', () => {
      const wrapper = btn.closest('.theme-toggle-wrapper');
      const select = wrapper?.querySelector('select');
      if (!select) return;
      select.value = btn.dataset.theme || 'auto';
      select.dispatchEvent(new Event('change', { bubbles: true }));
      wrapper?.querySelectorAll<HTMLButtonElement>('.theme-buttons button').forEach((b) => {
        b.toggleAttribute('data-active', b === btn);
      });
    });
  }

  // Sync initial active state from current theme
  const current = document.documentElement.dataset.theme;
  if (current) {
    document.querySelectorAll<HTMLButtonElement>(`.theme-buttons button[data-theme="${current}"]`).forEach((b) => {
      b.toggleAttribute('data-active', true);
    });
  }
</script>

<style>
  .theme-buttons {
    display: none;
    gap: 0.25rem;
  }

  .theme-buttons button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 0.375rem;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    padding: 0.4rem;
    line-height: 0;
  }

  .theme-buttons button:hover {
    color: var(--sl-color-white);
    background: var(--sl-color-gray-6);
  }

  .theme-buttons button[data-active] {
    color: var(--sl-color-white);
    border-color: var(--sl-color-gray-5);
    background: var(--sl-color-gray-6);
  }

  /* Mobile: show buttons, hide the default dropdown */
  @media (max-width: 50rem) {
    .theme-toggle-wrapper :global(starlight-theme-select) {
      display: none;
    }
    .theme-buttons {
      display: inline-flex;
    }
  }
</style>
